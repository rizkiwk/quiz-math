<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema window pasca-splash. Warna UI sebenarnya di-handle Compose MaterialTheme.
         Window background dark agar tak ada flash putih sebelum frame Compose pertama. -->
    <style name="Theme.MathBlow" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Kontras ikon status/nav bar diatur runtime (SideEffect di MainActivity) agar
             mengikuti tema terang/gelap; windowLightStatusBar statis dibuang karna salah utk tema terang. -->
    </style>

    <!-- Splash via androidx.core:core-splashscreen -->
    <style name="Theme.MathBlow.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.MathBlow</item>
    </style>
</resources>
