<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema window pasca-splash. Warna UI sebenarnya di-handle Compose MaterialTheme.
         Window background dark agar tak ada flash putih sebelum frame Compose pertama. -->
    <style name="Theme.MathSharp" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash via androidx.core:core-splashscreen -->
    <style name="Theme.MathSharp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.MathSharp</item>
    </style>
</resources>
